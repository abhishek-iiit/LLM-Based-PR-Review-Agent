# ── Required ──────────────────────────────────────────────────────────────────
# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...

# GitHub personal access token with repo + pull_requests scopes
GITHUB_TOKEN=ghp_...

# ── Optional - LLM settings ───────────────────────────────────────────────────
# Gemini model to use for review
LLM_MODEL=gemini-2.0-flash-lite

# Temperature for LLM responses (0.0 = deterministic)
LLM_TEMPERATURE=0.2

# Max output tokens per LLM call
LLM_MAX_TOKENS=4096

# Max retries on rate limit / transient errors
MAX_RETRIES=3

# ── Optional - Webhook server ─────────────────────────────────────────────────
# HMAC secret configured in GitHub webhook settings
WEBHOOK_SECRET=your-webhook-secret

# Server bind port
PORT=8080

# ── Optional - Logging ────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log format: json (production) | console (development)
LOG_FORMAT=json
